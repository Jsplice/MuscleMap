{
  "name": "@musclemap/react",
  "version": "0.2.0",
  "description": "React component for MuscleMap — premium, data-driven muscle heatmaps (flat vector or photoreal hybrid).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "musclemap",
    "muscle",
    "anatomy",
    "heatmap",
    "react",
    "fitness",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Jsplice/MuscleMap.git",
    "directory": "packages/react"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@musclemap/assets": "workspace:*",
    "@musclemap/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/react"
  }
}
