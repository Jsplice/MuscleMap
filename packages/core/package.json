{
  "name": "@musclemap/core",
  "version": "0.1.0",
  "description": "Headless core for MuscleMap — muscle-group types, color scales and region/visibility rules. UI-free.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "keywords": ["musclemap", "muscle", "anatomy", "heatmap", "fitness", "headless"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Jsplice/MuscleMap.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/core"
  }
}
