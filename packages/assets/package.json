{
  "name": "@musclemap/assets",
  "version": "0.1.0",
  "description": "Body diagrams for MuscleMap — segmented muscle SVG path data with semantic IDs and region viewBoxes. Framework-free.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bodies/*": "./bodies/*"
  },
  "files": ["dist", "bodies"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["musclemap", "muscle", "anatomy", "svg", "body"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Jsplice/MuscleMap.git",
    "directory": "packages/assets"
  },
  "dependencies": {
    "@musclemap/core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/assets"
  }
}
