{
  "name": "musclemap-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Premium, data-driven muscle heatmaps for the web — headless core + React, flat-vector or photoreal.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jsplice/MuscleMap.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @musclemap/playground dev",
    "build": "pnpm --filter \"./packages/*\" -r build",
    "typecheck": "pnpm --filter \"./packages/*\" -r typecheck",
    "verify:packages": "node scripts/verify-package-imports.mjs && tsc -p packages/react/consumer-tests/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm lint && pnpm build && pnpm verify:packages && pnpm typecheck && pnpm test && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
